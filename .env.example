DATABASE_URL="file:./dev.db"

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Session encryption key (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=generate_a_64_char_hex_string

# Default Copilot model
COPILOT_MODEL=gpt-4.1

# Set to true to log pipeline prompts/responses
DEBUG_PIPELINE=false
